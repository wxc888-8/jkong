# Telegram 机器人 token（不要提交真实 token）
TELEGRAM_BOT_TOKEN=REPLACE_ME

# 推送目标群/频道 chat_id；多个用逗号/分号分隔
TELEGRAM_CHAT_ID=-1003857333607

# 推送节流：两次发送之间最小间隔（秒）
TG_MIN_INTERVAL_SECONDS=1

# 管理员 Telegram 用户ID（多个用逗号/分号分隔；先私聊机器人 /whoami 获取）
TG_ADMIN_USER_IDS=123456789

# 失败交易筛选：TAO 等值 >= 该阈值才推送/打印
MIN_TAO_THRESHOLD=0.5

# 启动时拉取多少条“历史失败交易”用于回放
HISTORY_LIMIT=10

# 连接的链节点 WSS 地址
SUBSTRATE_WSS_URL=wss://entrypoint-finney.opentensor.ai:443

# 价格缓存刷新间隔（秒）
PRICE_REFRESH_SECONDS=30

# 每隔多少个新区块打印一次心跳；设为 0 关闭
HEARTBEAT_EVERY_BLOCKS=5

# 内存去重集合上限/收缩后保留数量（用于防止重复推送）
PROCESSED_HASHES_MAX=5000
PROCESSED_HASHES_KEEP=2000

# BOT2（地址监控机器人）配置
BOT2_TELEGRAM_BOT_TOKEN=REPLACE_ME
BOT2_TG_ADMIN_USER_IDS=123456789
BOT2_SUBSTRATE_WSS_URL=wss://entrypoint-finney.opentensor.ai:443
BOT2_DB_PATH=/app/data/bot2.db
BOT2_POLL_TIMEOUT=30
BOT2_PAGE_SIZE=10
BOT2_CONTACT=请联系管理员
